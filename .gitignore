# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
venv/

# Build
build/
dist/
*.egg-info/
CMakeFiles/
CMakeCache.txt
cmake-build-*/
compile_commands.json
*.o
*.so
*.dll
*.lib
*.a
# Bundled ONNX Runtime libs (see third_party section below) must be committed.
!third_party/onnxruntime-linux-x64-*/lib/*.so

# Training outputs
games/*/runs/
games/*/model/random

# Top-level training run artifacts (checkpoints, train.log, per-step ONNX
# snapshots). Each run can be hundreds of MB to GB. The deployed
# best_model.onnx under games/<id>/model/ IS committed so clones are
# playable out of the box — but the full training history stays local.
runs/

# Random-fallback ONNX cache (stale: the random-model fallback was removed
# but the cache files linger).
games/.random_models/

# ONNX Runtime (local dependency)
# Mac/Windows bundles stay local (devs install via brew / download themselves).
# The Linux x64 bundle IS committed so `git clone` on a Linux server is enough
# to build — avoids Alibaba Cloud shield dropping SSH when wget hits github.com.
third_party/onnxruntime-*/
!third_party/onnxruntime-linux-x64-*/

# Plans (private strategy docs)
docs/plans/

# Devlog (private daily notes)
docs/devlog/

# Ad-hoc scripts (local utility scripts)
script/

# Replay dumps (local debug artifacts — regenerate from selfplay / web)
games/*/replay/

# Secrets
*.pem
*.ppk
.env

# Logs
*.log
*.tmp

# Ad-hoc dev artifacts (debugging screenshots, scratch notes).
截图/
screenshots/

# Reference-only projects mounted for inspection (previous DinoBoard version,
# Mosaic, etc.). Not part of the build or version control.
参考项目/

# Benchmark snapshots — trained model checkpoints used as opponents for
# future training runs. Archived outside of runs/ so subsequent trainings
# don't overwrite them. Kept local (large, reproducible from train.log).
benchmarks/
