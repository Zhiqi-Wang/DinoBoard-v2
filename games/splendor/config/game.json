{
  "game_id": "splendor",
  "display_name": "Splendor",
  "players": {
    "min": 2,
    "max": 4
  },
  "action_space": 70,
  "feature_dim": 294,
  "has_hidden_info": true,
  "has_random_nodes": true,
  "random_node_modes": ["peek", "truncate", "nopeek"],
  "training": {
    "simulations": 200,
    "c_puct": 1.4,
    "temperature": 1.0,
    "temperature_schedule": {
      "enabled": true,
      "initial": 1.0,
      "final": 0.1,
      "decay_plies": 30
    },
    "dirichlet_alpha": 0.3,
    "dirichlet_epsilon": 0.25,
    "dirichlet_on_first_n_plies": 30,
    "max_game_plies": 160,
    "episodes_per_step": 400,
    "batch_size": 512,
    "learning_rate": 0.001,
    "steps": 20000
  },
  "network": {
    "type": "mlp",
    "hidden_layers": [256, 256, 128],
    "activation": "relu"
  }
}
