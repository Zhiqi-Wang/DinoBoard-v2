{
  "game_id": "tictactoe",
  "display_name": "Tic-Tac-Toe",
  "players": {
    "min": 2,
    "max": 2
  },
  "action_space": 9,
  "feature_dim": 28,
  "training": {
    "simulations": 100,
    "c_puct": 1.4,
    "temperature": 1.0,
    "temperature_initial": 1.0,
    "temperature_final": 0.1,
    "temperature_decay_plies": 6,
    "dirichlet_alpha": 1.0,
    "dirichlet_epsilon": 0.25,
    "dirichlet_on_first_n_plies": 9,
    "max_game_plies": 9,
    "episodes_per_step": 200,
    "batch_size": 256,
    "learning_rate": 0.001,
    "steps": 500
  },
  "network": {
    "type": "mlp",
    "hidden_layers": [
      64,
      64
    ],
    "activation": "relu"
  }
}
